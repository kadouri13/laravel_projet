        "/articles/{id}/status": {
            "put": {
                "tags": [
                    "Articles"
                ],
                "summary": "Update article status (Admin/Editor)",
                "operationId": "97f7e9ca17308e8aa801770be50adcf3",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of article",
                        "required": true,
