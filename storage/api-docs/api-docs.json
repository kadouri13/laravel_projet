    "paths": {
        "/articles/{id}/ai-detect": {
            "post": {
                "tags": [
                    "Articles"
                ],
                "summary": "Run a heuristic AI detection pre-consultation on an article",
                "operationId": "d552da27d7680e1a0d7e98aa774f75cb",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of the article",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "AI detection result",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "article_id": {
                                            "type": "integer"
                                        },
                                        "ai_probability": {
                                            "type": "integer"
                                        },
                                        "human_probability": {
                                            "type": "integer"
                                        },
                                        "decision": {
                                            "type": "string",
                                            "example": "AI Generated"
                                        },
                                        "disclaimer": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Article not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
